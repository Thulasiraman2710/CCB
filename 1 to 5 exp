'use strict';

const { Contract } = require('fabric-contract-api');

class RewardsContract extends Contract {

    async InitLedger(ctx) {
        console.info('Ledger initialized');
    }

    async IssueReward(ctx, memberID, points) {
        const reward = {
            memberID: memberID,
            points: parseInt(points)
        };

        await ctx.stub.putState(memberID, Buffer.from(JSON.stringify(reward)));
        return JSON.stringify(reward);
    }

    async GetReward(ctx, memberID) {
        const rewardJSON = await ctx.stub.getState(memberID);

        if (!rewardJSON || rewardJSON.length === 0) {
            throw new Error(`Reward for member ${memberID} not found`);
        }

        return rewardJSON.toString();
    }
}

module.exports = RewardsContract;



