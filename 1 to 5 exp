const { Gateway, Wallets } = require('fabric-network');
const path = require('path');
const fs = require('fs');

async function main() {
  try {
    const ccpPath = path.resolve(__dirname, '..', 'connection.json');
    const ccp = JSON.parse(fs.readFileSync(ccpPath, 'utf8'));

    const walletPath = path.join(process.cwd(), 'wallet');
    const wallet = await Wallets.newFileSystemWallet(walletPath);

    const gateway = new Gateway();

    await gateway.connect(ccp, {
      wallet,
      identity: 'user1',
      discovery: { enabled: true, asLocalhost: true }
    });

    const network = await gateway.getNetwork('mychannel');
    const contract = network.getContract('carAuction');

    // Create Auction
    await contract.submitTransaction('CreateAuction', 'CAR123', 'BMW');
    console.log('Auction created');

    // Place Bid
    await contract.submitTransaction('PlaceBid', 'CAR123', 'bidder1', '5000');
    console.log('Bid placed');

    // Get Auction
    const result = await contract.evaluateTransaction('GetAuction', 'CAR123');
    console.log('Auction Result:', result.toString());

    await gateway.disconnect();

  } catch (error) {
    console.error('Error:', error);
  }
}

main();




